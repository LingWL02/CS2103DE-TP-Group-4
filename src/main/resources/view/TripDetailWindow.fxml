<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="ui.TripDetailWindow" styleClass="app-root">
    <center>
        <VBox spacing="14" alignment="TOP_LEFT">
            <HBox spacing="16" alignment="CENTER_LEFT" styleClass="card">
                <StackPane styleClass="image-tile tile-nature small-tile">
                    <Label text="Nature" styleClass="tile-label" />
                </StackPane>
                <StackPane styleClass="image-tile tile-beach small-tile">
                    <Label text="Beach" styleClass="tile-label" />
                </StackPane>
                <VBox spacing="4">
                    <Label fx:id="tripNameLabel" styleClass="page-title" />
                    <Label fx:id="tripDateLabel" styleClass="muted" />
                    <Label fx:id="tripLocationLabel" styleClass="muted" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button text="Back" fx:id="backButton" styleClass="ghost-button" />
            </HBox>
        </VBox>
    </center>
    <padding>
        <Insets top="22" right="22" bottom="22" left="22" />
    </padding>
</BorderPane>
